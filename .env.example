APPLE_TEAM_ID=ABCDE12345
NEXT_PUBLIC_BUNDLE_IDENTIFIER=com.example.yourapp

NEXT_PUBLIC_APP_REDIRECT_URL=yourapp://checkout_redirect/success
NEXT_PUBLIC_PADDLE_ENV=sandbox # or `production`
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# PostHog product analytics (whole site: marketing pages, blog, quiz — ONE project)
NEXT_PUBLIC_POSTHOG_KEY=        # Project API key: posthog.com -> Settings -> Project
# Reverse proxy path — next.config.ts rewrites /ingest -> PostHog US (evades ad blockers).
# For EU region, change the rewrite targets in next.config.ts to eu(-assets).i.posthog.com.
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# Quiz funnel (/quiz) lead capture — see src/app/api/quiz-lead/route.ts
RESEND_API_KEY=            # Resend API key (sends welcome + notification emails)
RESEND_AUDIENCE_ID=        # Resend Audience to add quiz leads to (the nurture list)
QUIZ_LEAD_NOTIFY_EMAIL=hello@rythma.co  # where the internal "new lead" email (full answers + UTMs) is sent
